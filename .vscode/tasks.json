{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-o",
                "a.out",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "compile and run",
            "type": "shell",
            "command": "clear && g++ -std=c++17 -Wall -o a.out ${file} && echo '--- Running ---' && ./a.out < input.txt > output.txt && echo '✓ Done. Check output.txt' || echo '✗ Compilation or runtime error'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": false
            },
            "problemMatcher": "$gcc"
        }
    ]
}
